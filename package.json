{
  "name": "ai-news",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "typecheck": "vue-tsc --noEmit",
    "fetch": "tsx scripts/fetcher/index.ts",
    "fetch:dev": "tsx watch scripts/fetcher/index.ts"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.5",
    "autoprefixer": "^10.4.18",
    "cheerio": "^1.2.0",
    "commander": "^12.1.0",
    "dayjs": "^1.11.21",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "fast-xml-parser": "^4.5.0",
    "jsdom": "^29.1.1",
    "p-limit": "^6.1.0",
    "postcss": "^8.4.35",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.4.3",
    "vite": "^5.2.8",
    "vite-plugin-pwa": "^0.19.0",
    "vitest": "^1.5.0",
    "vue-tsc": "^2.0.10"
